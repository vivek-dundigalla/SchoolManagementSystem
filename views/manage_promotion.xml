<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_manage_promotion_form" model="ir.ui.view">
        <field name="name">ManagPromotion</field>
        <field name="model">exam.managepromotion</field>
        <field name="arch" type="xml">
            <form string="Manage Promotion">
                <sheet>
                    <group>
                        <field name="image" widget="image" class="oe_avatar"/>
                        <field name="name"/>
                        <field name="class_name"/>
                        <field name="section"/>
                        <field name="status"/>

                    </group>
                </sheet>
                 <footer>
            <button name="action_save_promotion" string="Save" type="object" class="btn-primary"/>
            <button string="Cancel" class="btn-secondary" special="cancel"/>
        </footer>
            </form>
        </field>
    </record>

    <record id="view_manage_promotion_list" model="ir.ui.view">
        <field name="name">ManagePromotion</field>
        <field name="model">exam.managepromotion</field>
        <field name="arch" type="xml">
            <list string="ManagePromotion">
            <field name="image" widget="image" class="oe_avatar"/>
                        <field name="name"/>
                <field name="class_name"/>

                <field name="section"/>
                <field name="status"/>

            </list>
        </field>

    </record>




    <record id="action_exam_manage_promotion" model="ir.actions.act_window">
        <field name="name">Manage Promotion</field>
        <field name="res_model">exam.managepromotion</field>
        <field name="view_mode">list,form</field>
        <!--        <field name="view_id" ref="view_teacher_list"/>-->
    </record>

</odoo>