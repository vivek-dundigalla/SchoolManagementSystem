<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_exam_promotion_form" model="ir.ui.view">
        <field name="name">exam.promotion.form</field>
        <field name="model">exam.promotion</field>
        <field name="arch" type="xml">
            <form string="Promotion">
                <header>
                    <button name="promoting_students" string="Promoting Students" type="object" class="oe_highlight"/>

                </header>
                <sheet>
                    <group>
                        <field name="class_name"/>
                        <field name="class_name1"></field>
                        <field name="current_session"></field>
                        <field name="next_session"></field>


                    </group>
                    <xpath expr="//field[@name='next_session']" position="after">
                        <button name="manage_promotion" string="Manage Promotion" type="object" class="oe_highlight"/>

                    </xpath>
                </sheet>

            </form>
        </field>
    </record>
    <record id="view_exam_promotion_list" model="ir.ui.view">
        <field name="name">exam.promotion.form</field>
        <field name="model">exam.promotion</field>
        <field name="arch" type="xml">
            <list string="Promotion">
                 <field name="class_name"/>
                        <field name="class_name1"></field>
                        <field name="current_session"></field>
                        <field name="next_session"></field>
            </list>
        </field>


    </record>


    <record id="action_exam_promotion" model="ir.actions.act_window">
        <field name="name">Promotion</field>
        <field name="res_model">exam.promotion</field>
        <field name="view_mode">form</field>
    </record>
</odoo>